{
  "name": "habits",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "bun src/database/seeds/dev.seed.ts",

    "docker:dev": "docker compose up -d postgres redis",
    "docker:dev:down": "docker-compose down",
    "docker:prod": "docker-compose -f docker-compose.yml up --build -d",
    "docker:prod:down": "docker-compose -f docker-compose.yml down",

    "setup" : "bun run docker:dev && bun run db:migrate && bun run test && bun run db:seed && bun run dev",

    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "pg": "^8.20.0",
    "zod": "^4.4.3"
  }
}